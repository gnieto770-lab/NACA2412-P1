FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      omega;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 -1 0 0 0 0];

internalField   uniform 16.0;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 16.0;
    }
    outlet
    {
        type            zeroGradient;
    }
    topAndBottom
    {
        type            zeroGradient;
    }
    perfil
    {
        type            omegaWallFunction;
        value           uniform 16.0;
    }
    frontAndBack
    {
        type            symmetry;
    }
}
